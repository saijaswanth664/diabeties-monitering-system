# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/

# Environment variables (contains secrets) - NEVER commit
.env
frontend/.env

# Database (SQLite local dev only - use cloud DB in production)
*.db

# Generated reports (runtime artifacts)
reports_generated/

# Node modules (auto-installed by npm install)
node_modules/
frontend/node_modules/

# Frontend build output (generated by npm run build)
frontend/dist/

# Lock files (optional, keep for reproducibility)
# package-lock.json

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Firebase service account (sensitive)
firebase_service_account.json

# Temporary / scratch
scratch/
e -Force .git
