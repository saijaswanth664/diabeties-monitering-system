# ── Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values

# JWT / Security
SECRET_KEY=your_super_secret_key_here_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database URL
# SQLite (local dev):  sqlite:///./diabetes.db
# PostgreSQL (Render): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./diabetes.db

# ── SMTP / Gmail for OTP & Report Emails ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_NAME=Secure AI Diabetes Monitoring System
